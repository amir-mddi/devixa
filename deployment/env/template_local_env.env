# ============================================================
# App Identity / Environment
# ============================================================
ENV=local
IS_DEBUG=True
APP_SECRET_KEY="replace_with_django_secret_key"
ENCRYPTION_KEY="replace_with_encryption_key"

ALLOWED_HOST="localhost,127.0.0.1"
ADMIN_PANEL_URL=admin/
PAGE_SIZE=20


# ============================================================
# Database
# ============================================================
USE_SQL_DATABASE=True
DATABASE_ENGINE=postgres
POSTGRES_NAME="dealio_local"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432


# ============================================================
# Redis / Celery
# ============================================================
REDIS_URL="localhost"
REDIS_PASSWORD=
REDIS_DB="1"
REDIS_PORT=6379
REDIS_MAX_CONNECTION=100

CELERY_BROKER_REDIS_DB="2"
CELERY_BACKEND_REDIS_DB="3"
CELERY_RUN_TIME_HOUR=23
CELERY_DB_INDEX_REDIS="0"


# ============================================================
# Email
# ============================================================
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USE_TLS="true"
EMAIL_HOST_USER="replace_with_email@gmail.com"
EMAIL_HOST_PASSWORD="replace_with_gmail_app_password"
DEFAULT_FROM_EMAIL="Devixa <replace_with_email@gmail.com>"


# ============================================================
# Security / Recaptcha / Sentry
# ============================================================
RECAPTCHA_SECRET_KEY="replace_with_recaptcha_secret"

USE_SENTRY=False
SENTRY_DSN=""
SENTRY_URL=""


# ============================================================
# CORS / Cross-Origin
# ============================================================
CROSS_ORIGIN_DOMAIN=http://localhost:8000,http://127.0.0.1:8000
CORS_ORIGIN_ALLOW_ALL=True
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_HEADERS="accept,accept-encoding,authorization,content-type,dnt,origin,user-agent,x-csrftoken,x-requested-with"
CORS_ALLOW_METHODS="DELETE,GET,OPTIONS,PATCH,POST,PUT"


# ============================================================
# Session
# ============================================================
SESSION_ENGINE=django.contrib.sessions.backends.cache
SESSION_CACHE_ALIAS=default
SESSION_COOKIE_AGE=3600
SESSION_EXPIRE_AT_BROWSER_CLOSE=False
SESSION_SAVE_EVERY_REQUEST=True

SESSION_COOKIE_NAME=sessionid
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_PATH=/
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax


# ============================================================
# CSRF
# ============================================================
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1
CSRF_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=False


# ============================================================
# Swagger / API Docs
# ============================================================
USE_SWAGGER=True
SWAGGER_DESCRIPTION="Local API Docs"
SWAGGER_DOCUMENTATION="Documentation of Devixa API."
SWAGGER_VERSION="1.0.0"


# ============================================================
# Initial Superuser
# ============================================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_PHONE_NUMBER=09000000000
DJANGO_SUPERUSER_EMAIL=admin@example.com


# ============================================================
# Proxy
# ============================================================
PROXY_URL=
# Example:
# PROXY_URL=http://username:password@proxy-host:proxy-port


# ============================================================
# OAuth
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/oauth/callback
OAUTH_DEFAULT_USER_ROLE_SYMBOL=user
OAUTH_HTTP_TIMEOUT_SECONDS=10


# ============================================================
# Telegram User API / Legacy Channel API
# Used only if project uses Telegram user/client API.
# ============================================================
API_ID=
API_HASH=
TELEGRAM_SESSION_FILE_NAME=
CHANNEL_ID=


# ============================================================
# Telegram Bot
# Editable bot settings priority: DB -> env -> default
# ============================================================
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_random_telegram_webhook_secret
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook/
TELEGRAM_WEBAPP_URL=

TELEGRAM_BOT_CLEAN_CHAT=False
TELEGRAM_PAYMENT_PROVIDER=card_to_card
TELEGRAM_LIST_PAGE_SIZE=5
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_POLLING_LIMIT=50
TELEGRAM_PROXY_URL=


# ============================================================
# Bale Bot
# Editable bot settings priority: DB -> env -> default
# ============================================================
BALE_BOT_TOKEN=replace_with_bale_bot_token
BALE_BOT_BASE_URL=https://tapi.bale.ai
BALE_WEBHOOK_SECRET=
BALE_WEBHOOK_URL=
BALE_WEBAPP_URL=

BALE_PAYMENT_PROVIDER=card_to_card
BALE_LIST_PAGE_SIZE=5
BALE_POLLING_TIMEOUT=30
BALE_POLLING_LIMIT=50
BALE_PROXY_URL=


# ============================================================
# Rubika Bot
# Editable bot settings priority: DB -> env -> default
# ============================================================
RUBIKA_BOT_TOKEN=replace_with_rubika_bot_token
RUBIKA_BOT_BASE_URL=https://botapi.rubika.ir/v3
RUBIKA_WEBHOOK_SECRET=
RUBIKA_WEBHOOK_URL=
RUBIKA_WEBAPP_URL=

RUBIKA_PAYMENT_PROVIDER=card_to_card
RUBIKA_LIST_PAGE_SIZE=5
RUBIKA_POLLING_LIMIT=50
RUBIKA_POLLING_SLEEP_SECONDS=5
RUBIKA_PROXY_URL=


# ============================================================
# Channel Sync
# ============================================================
CHANNEL_SYNC_ENABLED=true

CHANNEL_SYNC_TELEGRAM_SOURCE_CHAT_ID=
CHANNEL_SYNC_BALE_SOURCE_CHAT_ID=

CHANNEL_SYNC_TELEGRAM_TARGET_CHAT_ID=
CHANNEL_SYNC_BALE_TARGET_CHAT_ID=
CHANNEL_SYNC_RUBIKA_TARGET_CHAT_ID=


# ============================================================
# Channel Invite / Member Sync
# ============================================================
CHANNEL_INVITE_TELEGRAM_URL=
CHANNEL_INVITE_BALE_URL=
CHANNEL_INVITE_RUBIKA_URL=

CHANNEL_MEMBER_SYNC_TELEGRAM_CHAT_ID=
CHANNEL_MEMBER_SYNC_BALE_CHAT_ID=


# ============================================================
# Payment Base
# ============================================================
PAYMENT_SANDBOX_ENABLED=false


# ============================================================
# Card-to-Card Payment
# ============================================================
CARD_TO_CARD_CARD_NUMBER=
CARD_TO_CARD_ACCOUNT_NUMBER=
CARD_TO_CARD_ACCOUNT_OWNER=
CARD_TO_CARD_BANK_NAME=
CARD_TO_CARD_IBAN=
CARD_TO_CARD_PAYMENT_MESSAGE=Please transfer the exact amount and send the receipt in the bot or site panel.

# Backward-compatible aliases
CARD_TO_CARD_NUMBER=${CARD_TO_CARD_CARD_NUMBER}
CARD_TO_CARD_HOLDER=${CARD_TO_CARD_ACCOUNT_OWNER}


# ============================================================
# Pardakhtyar Payment Gateway
# Fill after receiving real Pardakhtyar credentials/docs.
# ============================================================
PARDAKHTYAR_MERCHANT_ID=
PARDAKHTYAR_REQUEST_URL=
PARDAKHTYAR_VERIFY_URL=
PARDAKHTYAR_START_PAY_BASE_URL=

PARDAKHTYAR_CALLBACK_URL=https://your-domain.com/api/v1/billing/payments/pardakhtyar/callback/
PARDAKHTYAR_SUCCESS_CODES=100,0,ok,success,succeeded,paid
PARDAKHTYAR_HTTP_TIMEOUT_SECONDS=12

PARDAKHTYAR_FRONTEND_SUCCESS_URL=https://your-frontend-domain.com/payment/success
PARDAKHTYAR_FRONTEND_FAILED_URL=https://your-frontend-domain.com/payment/failed


# ============================================================
# Backup / Arvan
# ============================================================
ARVAN_ACCESS_KEY=
ARVAN_SECRET_KEY=
ARVAN_REGION=
ARVAN_SERVICE_NAME=
ARVAN_BASE_URL=
ARVAN_BUCKET=


# ============================================================
# Monitoring / Metrics
# ============================================================
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc
METRIC_SERVICE_ENDPOINT=


