# Environment
ENV=production
APP_SECRET_KEY=
IS_DEBUG=True

# Email
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Sentry
SENTRY_DSN=
SENTRY_URL=
USE_SENTRY=False


# Redis
REDIS_URL=
REDIS_PASSWORD=
REDIS_USERNAME=default
REDIS_REQUIRE_FULL_COVERAGE=False
REDIS_DB=10
REDIS_PORT=6379
CELERY_BROKER_REDIS_DB=5
CELERY_BACKEND_REDIS_DB=6
CELERY_RUN_TIME_HOUR=23
CELERY_DB_INDEX_REDIS=0
REDIS_MAX_CONNECTION=100


# Database
USE_SQL_DATABASE=True
POSTGRES_NAME=dealio_db
POSTGRES_USER=backend
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=

# PgBouncer (DEV only)
PGBOUNCER_IP=
PGBOUNCER_PORT=
PGBOUNCER_POOL_MODE=
PGBOUNCER_MAX_CLIENT_CONN=
PGBOUNCER_DEFAULT_POOL_SIZE=

# Encryption
ENCRYPTION_KEY=

# Telegram
API_ID=
API_HASH=
TELEGRAM_SESSION_FILE_NAME=
CHANNEL_ID=


# CORS / Hosts
ALLOWED_HOST="127.0.0.1"
CROSS_ORIGIN_DOMAIN="http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,http://localhost:5173"
CORS_ORIGIN_ALLOW_ALL=False
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_HEADERS="accept,accept-encoding,authorization,content-type,dnt,origin,user-agent,x-csrftoken,x-requested-with"
CORS_ALLOW_METHODS="DELETE,GET,OPTIONS,PATCH,POST,PUT"


# Proxies / Celery


# Pagination
PAGE_SIZE=20

# Swagger (local-only, DEV had no value, so we keep)
USE_SWAGGER=True
SWAGGER_DESCRIPTION="Production API Docs"
SWAGGER_DOCUMENTATION="Documentation of CMC Collector Api. Note: The default page size is set to 20. The application has a single role called admin, which has no limitations."
SWAGGER_VERSION="1.0.1"


DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_PHONE_NUMBER=09021819682
DJANGO_SUPERUSER_EMAIL=admin@gmail.com
ADMIN_PANEL_URL=/


# Session Settings
SESSION_ENGINE=django.contrib.sessions.backends.cache
SESSION_CACHE_ALIAS=default
SESSION_COOKIE_AGE=3600
SESSION_EXPIRE_AT_BROWSER_CLOSE=False
SESSION_SAVE_EVERY_REQUEST=True

# Session Cookie Settings
SESSION_COOKIE_NAME=sessionid
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_PATH=/
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=None

# CSRF Settings
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1
CSRF_COOKIE_SAMESITE=None
CSRF_COOKIE_SECURE=True


# backup
ARVAN_ACCESS_KEY=
ARVAN_SECRET_KEY="SECRET_KEY"
ARVAN_REGION=
ARVAN_SERVICE_NAME=
ARVAN_BASE_URL=
ARVAN_BUCKET=

PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

METRIC_SERVICE_ENDPOINT=